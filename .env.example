# ==========================================
# Phoenix Core - Environment Variables Template
# Copy this file to `.env` and fill in real values.
# Never commit the actual `.env` file.
# ==========================================

# --- AI Layer (DeepSeek — single provider, V1) ---
PHOENIX_AI_DEEPSEEK_API_KEY=
PHOENIX_AI_DEEPSEEK_MODEL=deepseek-chat
PHOENIX_AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
PHOENIX_AI_DEEPSEEK_TIMEOUT=30
PHOENIX_AI_DEEPSEEK_MAX_RETRIES=3
# Max allowed /ask prompt length, in characters (default: 4000)
AI_MAX_PROMPT_LENGTH=4000
# Conversation Memory Engine (Task 010)
AI_MAX_CONVERSATION_MESSAGES=20
AI_MAX_CONTEXT_CHARS=8000
# AI Guard Layer (Task 011)
AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_WINDOW=60
AI_GUARD_MAX_CONTEXT_CHARS=12000
AI_GUARD_MAX_RETRIES=2
# Conversation storage backend (Task 012)
MEMORY_BACKEND=sqlite
SQLITE_DATABASE=phoenix.db

# --- Telegram (bot: /start /help /version /status /health /repo /issues /plugins /ai /ask /reset /memory) ---
PHOENIX_TELEGRAM_BOT_TOKEN=

# --- GitHub ---
PHOENIX_GITHUB_TOKEN=
PHOENIX_GITHUB_OWNER=
PHOENIX_GITHUB_REPO=

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PHOENIX_SECURITY_SECRET_KEY=

# --- Logging (optional, defaults shown) ---
PHOENIX_LOG_LEVEL=INFO
PHOENIX_LOG_FORMAT=json
